---
import BaseLayout from "../layouts/BaseLayout.astro";
import CvContent from "../markdown/cv.md";
---

<BaseLayout
  title="CV | Chu Chen"
  description="Curriculum Vitae of Chu Chen."
  canonical="https://chuchen1206.github.io/cv"
>
  <section class="hero hero-grid">
    <div>
      <h1>Curriculum Vitae</h1>
      <p class="muted"></p>
      <!-- <p><a href="/files/CV.pdf">Download full CV (PDF)</a></p> -->
      <div class="info-bar">
        <span class="chip">Education</span>
        <span class="chip">Research</span>
        <span class="chip">Affliations</span>
      </div>
    </div>
    <div class="hero-visual">
      <img src="/images/converted/jpg/me_atHK.jpg" alt="CV visual placeholder" />
    </div>
  </section>

  <article class="card section">
    <CvContent />
  </article>
</BaseLayout>
