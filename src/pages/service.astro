---
import BaseLayout from "../layouts/BaseLayout.astro";
import { service } from "../data/service";
---

<BaseLayout
  title="Service | Chu Chen"
  description="Academic service, reviewing, and teaching activities by Chu Chen."
  canonical="https://chuchen1206.github.io/service"
>
  <section class="hero">
    <div>
      <h1 class="service-title">Professional Services</h1>
      <p class="muted">Academic leadership, reviewing, and teaching activities.</p>
      <!-- <div class="info-bar">
        <span class="chip">Conference Organizer</span>
        <span class="chip">Reviewer</span>
        <span class="chip">Teaching</span>
      </div> -->
    </div>
  </section>

  <section class="service-stack section">
    <article class="card">
      <h2>Organizer</h2>
      <ul>
        {service.organizer.map((item) => (
          <li>
            <a href={item.link} target="_blank" rel="noopener noreferrer">{item.item}</a>
          </li>
        ))}
      </ul>
    </article>
    <article class="card">
      <h2>Reviewer</h2>
      <ul>{service.reviewer.map((item) => <li>{item}</li>)}</ul>
    </article>
    <article class="card">
      <h2>Professional Service</h2>
      <ul>
        {service.professional.map((item) => (
          <li>{item.role}, {item.org} ({item.period})</li>
        ))}
      </ul>
    </article>
    <article class="card">
      <h2>Teaching</h2>
      <ul>{service.teaching.map((item) => <li>{item}</li>)}</ul>
    </article>
  </section>
</BaseLayout>
