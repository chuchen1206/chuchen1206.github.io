---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
import { publications } from "../data/publications";

const featured = publications
  .filter((item) => item.category !== "patent")
  .sort((a, b) => b.year - a.year)
  .slice(0, 3);

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.title,
  worksFor: { "@type": "Organization", name: profile.subtitle },
  email: `mailto:${profile.emails[0]}`,
  url: "https://chuchen.99.github.io",
  sameAs: [
    profile.links.orcid,
    profile.links.linkedin,
    profile.links.scholar,
    profile.links.github
  ]
};
---

<BaseLayout
  title="Chu Chen | Academic Homepage"
  description="Academic homepage of Chu Chen: research in scientific computing, inverse problems, and medical imaging."
  canonical="https://chuchen.99.github.io/"
  jsonLd={personJsonLd}
>
  <section class="hero hero-grid">
    <div>
      <h1>{profile.name}</h1>
      <p class="muted">{profile.title} · {profile.subtitle}</p>
      <p>{profile.tagline}</p>
      <p>
        <strong>Email:</strong> {profile.emails.join(" | ")}
      </p>
      <p>
        <strong>Address:</strong> {profile.location}
      </p>
      <ul class="social-links">
        <li>
          <a class="social-link-item" href={profile.links.orcid} target="_blank" rel="noopener noreferrer">
            <img class="social-icon" src="/images/icon-orcid.svg" alt="ORCID logo" />
            <span>ORCID</span>
          </a>
        </li>
        <li>
          <a class="social-link-item" href={profile.links.scholar} target="_blank" rel="noopener noreferrer">
            <img class="social-icon" src="/images/icon-scholar.svg" alt="Google Scholar logo" />
            <span>Google Scholar</span>
          </a>
        </li>
        <li>
          <a class="social-link-item" href={profile.links.linkedin} target="_blank" rel="noopener noreferrer">
            <img class="social-icon" src="/images/icon-linkedin.svg" alt="LinkedIn logo" />
            <span>LinkedIn</span>
          </a>
        </li>
        <li>
          <a class="social-link-item" href={profile.links.github} target="_blank" rel="noopener noreferrer">
            <img class="social-icon" src="/images/icon-github.svg" alt="GitHub logo" />
            <span>GitHub</span>
          </a>
        </li>
      </ul>
      <div class="info-bar">
      <!--  <span class="chip">Medical Imaging</span> -->
      <!--  <span class="chip">Inverse Problems</span> -->
      <!--  <span class="chip">Deep Learning</span> -->
      </div>
    </div>
    <div class="hero-visual">
      <img src="/images/chu.heic" alt="Profile placeholder" />
    </div>
  </section>

  <section class="section">
    <h2>Research Interests</h2>
    <div class="card">
      <p>{profile.researchInterests.join(" · ")}</p>
    </div>
  </section>

  <section class="section">
    <h2>Position</h2>
    <div class="grid">
      {
        profile.positions.map((position) => (
          <article class="card position-card">
            <h3>{position.role}</h3>
            {position.logo && (
              <img
                class="institution-logo"
                src={position.logo}
                alt={position.logoAlt ?? `${position.institution} logo`}
              />
            )}
            <p class="muted">{position.institution}</p>
            {position.period && <p>{position.period}</p>}
            {position.advisor && <p>{position.advisor}</p>}
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <h2>Selected Publications</h2>
    <div class="pub-list">
      {
        featured.map((item) => (
          <article class="card pub-card">
            <h3>{item.title}</h3>
            <p class="muted">{item.authors}</p>
            <p>
              {item.venue} ({item.year}) <span class="badge">{item.category}</span>
            </p>
          </article>
        ))
      }
    </div>
    <p>
      <a href="/publications">View full publication list →</a>
    </p>
  </section>

  <section class="section">
    <h2>Research Visual Highlights</h2>
    <p class="muted">Use these placeholders for your project figures, conference photos, or lab snapshots.</p>
    <div class="gallery">
      <img src="/images/research-visual-1.svg" alt="Research figure placeholder 1" />
      <img src="/images/research-visual-2.svg" alt="Research figure placeholder 2" />
    </div>
  </section>
</BaseLayout>
