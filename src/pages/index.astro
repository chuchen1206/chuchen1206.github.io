---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
import { publications } from "../data/publications";

const featured = publications
  .filter((item) => item.category !== "patent")
  .sort((a, b) => b.year - a.year)
  .slice(0, 3);

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.title,
  worksFor: { "@type": "Organization", name: profile.subtitle },
  email: `mailto:${profile.emails[0]}`,
  url: "https://chuchen.99.github.io",
  sameAs: [
    profile.links.orcid,
    profile.links.linkedin,
    profile.links.scholar,
    profile.links.github
  ]
};
---

<BaseLayout
  title="Chu Chen | Academic Homepage"
  description="Academic homepage of Chu Chen: research in scientific computing, inverse problems, and medical imaging."
  canonical="https://chuchen.99.github.io/"
  jsonLd={personJsonLd}
>
  <section class="hero">
    <h1>{profile.name}</h1>
    <p class="muted">{profile.title} · {profile.subtitle}</p>
    <p>{profile.tagline}</p>
    <p>
      <strong>Email:</strong> {profile.emails.join(" | ")}
    </p>
    <p>
      <a href={profile.links.orcid} target="_blank" rel="noopener noreferrer">ORCID</a> ·
      <a href={profile.links.scholar} target="_blank" rel="noopener noreferrer"> Google Scholar</a> ·
      <a href={profile.links.linkedin} target="_blank" rel="noopener noreferrer"> LinkedIn</a> ·
      <a href={profile.links.github} target="_blank" rel="noopener noreferrer"> GitHub</a>
    </p>
  </section>

  <section>
    <h2>Research Interests</h2>
    <div class="card">
      <p>{profile.researchInterests.join(" · ")}</p>
    </div>
  </section>

  <section>
    <h2>Current and Recent Positions</h2>
    <div class="grid">
      {
        profile.positions.map((position) => (
          <article class="card">
            <h3>{position.role}</h3>
            <p class="muted">{position.institution}</p>
            <p>{position.period}</p>
            <p>{position.advisor}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section>
    <h2>Selected Publications</h2>
    <div class="grid">
      {
        featured.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p class="muted">{item.authors}</p>
            <p>
              {item.venue} ({item.year}) <span class="badge">{item.category}</span>
            </p>
          </article>
        ))
      }
    </div>
    <p>
      <a href="/publications">View full publication list →</a>
    </p>
  </section>
</BaseLayout>
