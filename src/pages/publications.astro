---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publications } from "../data/publications";

const groups = [
  { key: "journal", label: "Journal" },
  { key: "conference", label: "Conference" },
  { key: "preprint", label: "Preprint" },
  { key: "patent", label: "Patent" }
] as const;

const jsonLd = publications
  .filter((item) => item.category !== "patent")
  .map((item) => ({
    "@context": "https://schema.org",
    "@type": "ScholarlyArticle",
    headline: item.title,
    author: item.authors.split(";").map((name) => ({ "@type": "Person", name: name.trim() })),
    datePublished: String(item.year),
    isPartOf: item.venue,
    url: item.link ?? "https://chuchen.99.github.io/publications"
  }));
---

<BaseLayout
  title="Publications | Chu Chen"
  description="Publications, preprints, and patent by Chu Chen."
  canonical="https://chuchen.99.github.io/publications"
  jsonLd={jsonLd}
>
  <section class="hero hero-grid">
    <div>
      <h1>Publications</h1>
      <p class="muted">Journals, conferences, preprints, and patent. Each section is collapsible for readability.</p>
      <div class="info-bar">
        <span class="chip">Grouped by type</span>
        <span class="chip">Recent first</span>
        <span class="chip">Link-ready entries</span>
      </div>
    </div>
    <div class="hero-visual">
      <img src="/images/research-visual-1.svg" alt="Publications visual placeholder" />
    </div>
  </section>

  {
    groups.map((group) => {
      const items = publications
        .filter((item) => item.category === group.key)
        .sort((a, b) => b.year - a.year);

      if (items.length === 0) return null;

      return (
        <section class="section">
          <details open>
            <summary class="summary-title">
              <h2>{group.label}</h2>
              <span class="summary-count">{items.length} items</span>
            </summary>
            <div class="pub-list" style="margin-top: 0.9rem;">
              {items.map((item) => (
                <article class="card pub-card">
                  <h3>{item.title}</h3>
                  <p class="muted">{item.authors}</p>
                  <p>
                    {item.venue} ({item.year}) <span class="badge">{item.category}</span>
                  </p>
                  {item.link && (
                    <p>
                      <a href={item.link} target="_blank" rel="noopener noreferrer">
                        Read online
                      </a>
                    </p>
                  )}
                </article>
              ))}
            </div>
          </details>
        </section>
      );
    })
  }
</BaseLayout>
